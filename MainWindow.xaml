<Window x:Class="BIMData.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BIMData"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="1100" Background="#FFDDDDDD">
    <Window.Resources>
        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderThickness="2,0,0,0"
                                BorderBrush="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#094771"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#007ACC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="UserMessageStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Padding" Value="10,8,10,8"/>
            <Setter Property="Margin" Value="50,5,5,5"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>

        <Style x:Key="AgentMessageStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#EAEAEA"/>
            <Setter Property="Foreground" Value="#222222"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Padding" Value="10,8,10,8"/>
            <Setter Property="Margin" Value="5,5,50,5"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="48"/>
            <ColumnDefinition Width="*" MinWidth="450"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="320" MinWidth="250" MaxWidth="500"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#2D2D2D"
                BorderBrush="#3F3F46" BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Top">
                    <Button Style="{StaticResource SidebarButton}" ToolTip="Explorer"
                            Click="OnSidebarButtonClick" Tag="Explorer">
                        <Path Data="M20,18H4V8H20M20,6H12L10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6Z"
                              Fill="#CCCCCC" Stretch="Uniform" Width="18" Height="18"/>
                    </Button>
                    <Button Style="{StaticResource SidebarButton}" ToolTip="Szukaj"
                            Click="OnSidebarButtonClick" Tag="Search">
                        <Path Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z"
                              Fill="#CCCCCC" Stretch="Uniform" Width="18" Height="18"/>
                    </Button>
                    <Button Style="{StaticResource SidebarButton}" ToolTip="Narzedzia"
                            Click="OnSidebarButtonClick" Tag="Tools">
                        <Path Data="M13.78,15.3L19.78,21.3L21.22,19.86L15.22,13.86L13.78,15.3M17.5,10.1C17.11,10.1 16.69,10.05 16.36,9.91L4.97,21.25L3.06,19.34L10.2,12.2L8.5,10.5L7.14,11.86L5.72,10.45L7.14,9.03L5.72,7.62L7.14,6.2C8.34,5 10.14,5 11.34,6.2L13.25,8.11C14.26,7.67 15.5,7.91 16.28,8.69L14.5,10.5C14.23,10.23 13.88,10.1 13.5,10.1H17.5Z"
                              Fill="#CCCCCC" Stretch="Uniform" Width="18" Height="18"/>
                    </Button>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom">
                    <Button Style="{StaticResource SidebarButton}" ToolTip="Wyloguj"
                            Click="OnSidebarButtonClick" Tag="Logout">
                        <Path Data="M17,17.25V14H10V10H17V6.75L22.25,12L17,17.25M13,2A2,2 0 0,1 15,4V8H13V4H4V20H13V16H15V20A2,2 0 0,1 13,22H4A2,2 0 0,1 2,20V4A2,2 0 0,1 4,2H13Z"
                              Fill="#CCCCCC" Stretch="Uniform" Width="18" Height="18"/>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
            <Grid Background="#F5F5F5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="21*"/>
                    <RowDefinition Height="52*"/>
                </Grid.RowDefinitions>
                <local:ExplorerPanel x:Name="ExplorerContent" Visibility="Visible" Grid.RowSpan="2"/>
                <local:SearchPanel x:Name="SearchContent" Visibility="Collapsed" Grid.RowSpan="2"/>
                <local:ExcelPanel x:Name="ExcelPanelContent" Visibility="Collapsed" Grid.RowSpan="2"/>
            </Grid>
        </ScrollViewer>

        <GridSplitter Grid.Column="2" Width="4" 
                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch" 
                      Background="#D0D0D0" ResizeBehavior="PreviousAndNext"/>

        <Grid Grid.Column="3" Background="#F0F4F8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#1E1E24" Padding="12,10,12,10">
                <StackPanel Orientation="Horizontal">
                    <Path Data="M19,2H5A2,2 0 0,0 3,4V18A2,2 0 0,0 5,20H9V22H11V20H13V22H15V20H19A2,2 0 0,0 21,18V4A2,2 0 0,0 19,2M12,6A3,3 0 0,1 15,9A3,3 0 0,1 12,12A3,3 0 0,1 9,9A3,3 0 0,1 12,6M18,16H6V15C6,13 10,11.9 12,11.9C14,11.9 18,13 18,15V16Z" 
                          Fill="#54B4D3" Stretch="Uniform" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="AI Agent" Foreground="White" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                    <Ellipse Width="8" Height="8" Fill="#4CAF50" Margin="10,0,0,0" VerticalAlignment="Center" ToolTip="MCP Server Connected"/>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="5">
                <StackPanel x:Name="ChatHistoryStack">
                    <TextBox Style="{StaticResource AgentMessageStyle}" 
                             Text="Cześć! Jestem Twoim asystentem BIM. W czym mogę Ci dzisiaj pomóc?"/>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="ChatInputTextBox" Grid.Column="0" 
                             MinHeight="36" MaxHeight="100"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             VerticalContentAlignment="Center">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Padding" Value="8,4,8,4"/>
                                <Setter Property="BorderBrush" Value="#CCCCCC"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Background" Value="White"/>

                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="Zadaj pytanie agentowi..." Foreground="#999999" FontStyle="Italic" Margin="10,0,0,0"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <Button Grid.Column="1" Width="40" Height="36" Margin="6,0,0,0" 
                            Background="#007ACC" BorderThickness="0" Cursor="Hand"
                            x:Name="SendButton" Click="OnSendButtonClick">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="3"/>
                            </Style>
                        </Button.Resources>
                        <Path Data="M2,21L23,12L2,3V10L17,12L2,14V21Z" Fill="White" 
                              Stretch="Uniform" Width="14" Height="14" HorizontalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>