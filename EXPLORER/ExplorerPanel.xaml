<UserControl x:Class="BIMData.ExplorerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F5">

    <UserControl.Resources>
        <Style x:Key="TileButton" TargetType="Button">
            <Setter Property="Background" Value="#EBEBEB"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="200"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="14,8">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#DCDCDC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#C8C8C8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionHeader" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20,24,20">

            <Button Style="{StaticResource SectionHeader}" Click="ToggleBazyDanych">
                <Grid Width="640">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock x:Name="BazyDanychArrow" Text="▼"
                                   FontSize="10" Foreground="#555555"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="BAZY DANYCH"
                                   FontSize="11" FontWeight="SemiBold" Foreground="#555555"/>
                    </StackPanel>

                    <Border x:Name="AktualnaBazaBorder"
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            Background="#F3F3F3"
                            BorderBrush="#D0D0D0"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8,3">
                        <TextBlock x:Name="AktualnaBazaLabel"
                                   Text="Nie wczytano bazy"
                                   FontSize="11"
                                   Foreground="#666666"/>
                    </Border>
                </Grid>
            </Button>

            <WrapPanel x:Name="BazyDanychContent" Margin="0,0,0,20">
                <Button Style="{StaticResource TileButton}" Click="OnUtworzBaze">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Viewbox Width="30" Height="30" Margin="0,0,10,0">
                            <Canvas Width="24" Height="24">
                                <Ellipse Width="24" Height="24" Stroke="#333333" StrokeThickness="1.5" Fill="Transparent"/>
                                <Line X1="12" Y1="6" X2="12" Y2="18" Stroke="#333333" StrokeThickness="1.5"/>
                                <Line X1="6" Y1="12" X2="18" Y2="12" Stroke="#333333" StrokeThickness="1.5"/>
                            </Canvas>
                        </Viewbox>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Utwórz" FontWeight="Bold" FontSize="12" Foreground="#222222"/>
                            <TextBlock Text="Nowa baza danych" FontSize="10" Foreground="#666666"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource TileButton}" Click="OnWczytajBaze">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Viewbox Width="30" Height="30" Margin="0,0,10,0">
                            <Canvas Width="24" Height="24">
                                <Path Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20Z" Fill="#333333"/>
                            </Canvas>
                        </Viewbox>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Wczytaj" FontWeight="Bold" FontSize="12" Foreground="#222222"/>
                            <TextBlock Text="Istniejąca baza" FontSize="10" Foreground="#666666"/>
                        </StackPanel>
                    </StackPanel>
                </Button>


            </WrapPanel>

            <Separator Background="#DDDDDD" Margin="0,0,0,20"/>

            <Button Style="{StaticResource SectionHeader}" Click="ToggleProjekt">
                <Grid Width="640">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock x:Name="ProjektArrow" Text="▼"
                                   FontSize="10" Foreground="#555555"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="PROJEKT"
                                   FontSize="11" FontWeight="SemiBold" Foreground="#555555"/>
                    </StackPanel>

                    <Border x:Name="AktualnyProjektBorder"
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            Background="#F3F3F3"
                            BorderBrush="#D0D0D0"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8,3">
                        <TextBlock x:Name="AktualnyProjektLabel"
                                   Text="Nie wybrano projektu"
                                   FontSize="11"
                                   Foreground="#666666"/>
                    </Border>
                </Grid>
            </Button>

            <WrapPanel x:Name="ProjektContent" Margin="0,0,0,20">


                <Button Style="{StaticResource TileButton}" Click="OnWczytajProjekt">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Viewbox Width="30" Height="30" Margin="0,0,10,0">
                            <Canvas Width="24" Height="24">
                                <Path Data="M20,6H12L10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6Z" Fill="#333333"/>
                            </Canvas>
                        </Viewbox>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Zarządzanie projektami" FontWeight="Bold" FontSize="12" Foreground="#222222"/>
                            <TextBlock Text="Wybierz projekt" FontSize="10" Foreground="#666666"/>
                        </StackPanel>
                    </StackPanel>
                </Button>


            </WrapPanel>

            <Separator Background="#DDDDDD" Margin="0,0,0,20"/>

            <Button Style="{StaticResource SectionHeader}" Click="ToggleWczytajDane">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="WczytajDaneArrow" Text="▼"
                               FontSize="10" Foreground="#555555"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="WCZYTAJ DANE"
                               FontSize="11" FontWeight="SemiBold" Foreground="#555555"/>
                </StackPanel>
            </Button>

            <WrapPanel x:Name="WczytajDaneContent" Margin="0,0,0,20">
                <Button Style="{StaticResource TileButton}" Click="OnWczytajCsv">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Viewbox Width="30" Height="30" Margin="0,0,10,0">
                            <Canvas Width="24" Height="24">
                                <Path Data="M4,4H20V20H4V4M6,6V18H18V6H6M8,8H16V10H8V8M8,12H16V14H8V12" Fill="#333333"/>
                            </Canvas>
                        </Viewbox>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Wczytaj CSV" FontWeight="Bold" FontSize="12" Foreground="#222222"/>
                            <TextBlock Text="Import z pliku .csv" FontSize="10" Foreground="#666666"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource TileButton}" Click="OnPolaczRevit">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Viewbox Width="30" Height="30" Margin="0,0,10,0">
                            <Canvas Width="24" Height="24">
                                <Path Data="M12,2L2,7L12,12L22,7L12,2M2,17L12,22L22,17M2,12L12,17L22,12"
                      Stroke="#333333" StrokeThickness="1.5" Fill="Transparent"/>
                            </Canvas>
                        </Viewbox>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Revit" FontWeight="Bold" FontSize="12" Foreground="#222222"/>
                            <TextBlock Text="Połącz" FontSize="10" Foreground="#666666"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource TileButton}" Click="OnPolaczArchicad">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Viewbox Width="30" Height="30" Margin="0,0,10,0">
                            <Canvas Width="24" Height="24">
                                <Path Data="M3,21L12,3L21,21H3M12,7L6.5,18H17.5L12,7Z"
                      Stroke="#333333" StrokeThickness="1.5" Fill="Transparent"/>
                            </Canvas>
                        </Viewbox>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Archicad" FontWeight="Bold" FontSize="12" Foreground="#222222"/>
                            <TextBlock Text="Połącz" FontSize="10" Foreground="#666666"/>
                        </StackPanel>
                    </StackPanel>
                </Button>
            </WrapPanel>


        </StackPanel>
    </ScrollViewer>
</UserControl>